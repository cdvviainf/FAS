# ============================================================
# Variables para el demo en Coolify
# Copiar como referencia — configurar en la UI de Coolify,
# NO subir este archivo con valores reales al repositorio.
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_USER=fas_user
DB_PASSWORD=CAMBIAR_password_seguro
DB_NAME=fas_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_redis_password_seguro

# ── Auth (Better Auth) ───────────────────────────────────────
# Mínimo 32 caracteres — generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=CAMBIAR_minimo_32_caracteres_xxxxxxxxxxxxxxxx

# ── URLs públicas ────────────────────────────────────────────
# Asignar los subdominios reales configurados en Coolify
API_PUBLIC_URL=https://api-fas-demo.tudominio.cl
WEB_PUBLIC_URL=https://fas-demo.tudominio.cl

# ── Build arg para Next.js (se embebe en el bundle) ─────────
# Debe coincidir con API_PUBLIC_URL + /api
NEXT_PUBLIC_API_URL=https://api-fas-demo.tudominio.cl/api

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@agrosan.cl

# ── DTE ─────────────────────────────────────────────────────
DTE_PROVIDER=mock
# DTE_PROVIDER=chilesystems
# DTE_API_URL=https://api.chilesystems.cl
# DTE_API_KEY=xxxx

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@viain.cl
PGADMIN_PASSWORD=CAMBIAR_pgadmin_password
