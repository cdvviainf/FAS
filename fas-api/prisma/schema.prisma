generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS Y AUTH ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Better Auth fields
  emailVerified Boolean   @default(false)
  image         String?
  // admin plugin
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── AUTORIZACIÓN: ÍTEMS DE MENÚ, PERFILES Y USUARIOS ───────────────────────

enum NivelAcceso {
  SIN_ACCESO
  LECTURA
  TOTAL
}

model ItemMenu {
  id       Int            @id @default(autoincrement())
  codigo   String         @unique
  nombre   String
  seccion  String
  ruta     String?
  esAccion Boolean        @default(false)
  orden    Int            @default(0)
  activo   Boolean        @default(true)
  accesos  PerfilAcceso[]

  @@map("items_menu")
}

model Perfil {
  id             Int            @id @default(autoincrement())
  codigo         String
  descripcion    String
  accesos        PerfilAcceso[]
  usuarios       Usuario[]
  creadoEn       DateTime       @default(now())
  creadoPor      String
  actualizadoEn  DateTime?      @updatedAt
  actualizadoPor String?
  eliminadoEn    DateTime?
  eliminadoPor   String?

  @@map("perfiles")
}

model PerfilAcceso {
  id         Int         @id @default(autoincrement())
  perfilId   Int
  perfil     Perfil      @relation(fields: [perfilId], references: [id])
  itemMenuId Int
  itemMenu   ItemMenu    @relation(fields: [itemMenuId], references: [id])
  nivel      NivelAcceso @default(SIN_ACCESO)

  @@unique([perfilId, itemMenuId])
  @@map("perfil_accesos")
}

model Usuario {
  id             String    @id
  nombre         String
  email          String
  whatsapp       String?
  imagenUrl      String?
  perfilId       Int
  perfil         Perfil    @relation(fields: [perfilId], references: [id])
  creadoEn       DateTime  @default(now())
  creadoPor      String?
  actualizadoEn  DateTime? @updatedAt
  actualizadoPor String?
  eliminadoEn    DateTime?
  eliminadoPor   String?

  solicitudesAsignadas SolicitudInspeccionAsignado[]
  avatar               UsuarioAvatar?

  @@map("usuarios")
}

// Avatar del usuario (UP7): metadata en Usuario.imagenUrl (ruta de servido, no editable
// manualmente), binario aquí — mismo patrón que DocumentoArticulo/DocumentoArticuloContenido.
model UsuarioAvatar {
  usuarioId String   @id
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  mime      String
  tamano    Int
  datos     Bytes
  creadoEn  DateTime @default(now())

  @@map("usuarios_avatar")
}

// ─── ENTIDADES MAESTRAS ──────────────────────────────────────────────────────

model Productor {
  id            String    @id @default(cuid())
  rut           String    @unique
  nombre        String
  razonSocial   String
  email         String?
  telefono      String?
  direccion     String?
  comuna        String?
  region        String?
  banco         String?
  tipoCuenta    String?
  numeroCuenta  String?
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  ordenesCompra OrdenCompra[]
}

model Cliente {
  id         String      @id @default(cuid())
  codigo     String      @unique
  nombre     String
  pais       String
  mercado    MercadoType
  email      String?
  contacto   String?
  activo     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  notasVenta NotaVenta[]
}

enum MercadoType {
  SUDAMERICA
  NORTEAMERICA
  EUROPA
  ASIA
  OTRO
}

model EspecieLegacy {
  id        String           @id @default(cuid())
  nombre    String           @unique
  activo    Boolean          @default(true)

  variedades VariedadLegacy[]

  @@map("legacy_especies")
}

model VariedadLegacy {
  id         String         @id @default(cuid())
  nombre     String
  especieId  String
  especie    EspecieLegacy  @relation(fields: [especieId], references: [id])
  activo     Boolean        @default(true)

  @@unique([nombre, especieId])
  ordenesCompra OrdenCompraItem[]
  stockLotes    StockLote[]

  @@map("legacy_variedades")
}

// ─── COMPRAS ─────────────────────────────────────────────────────────────────

model OrdenCompra {
  id            String      @id @default(cuid())
  numero        String      @unique
  productorId   String
  productor     Productor   @relation(fields: [productorId], references: [id])
  temporada     String
  fechaEmision  DateTime
  fechaEntrega  DateTime?
  estado        OcEstado    @default(BORRADOR)
  observaciones String?
  montoTotal    Decimal     @db.Decimal(18, 4)
  aprobadoPor   String?
  aprobadoAt    DateTime?
  createdBy     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  items      OrdenCompraItem[]
  pagos      PagoProductor[]
  stockLotes StockLote[]
}

enum OcEstado {
  BORRADOR
  ENVIADA
  APROBADA
  RECIBIDA_PARCIAL
  RECIBIDA_TOTAL
  ANULADA
}

model OrdenCompraItem {
  id              String         @id @default(cuid())
  ordenCompraId   String
  ordenCompra     OrdenCompra    @relation(fields: [ordenCompraId], references: [id])
  variedadId      String
  variedad        VariedadLegacy @relation(fields: [variedadId], references: [id])
  calibre         String?
  categoria       String?
  unidad          String      @default("CAJA")
  cantidadPactada Decimal     @db.Decimal(18, 4)
  precioUnitario  Decimal     @db.Decimal(18, 4)
  montoTotal      Decimal     @db.Decimal(18, 4)
}

model PagoProductor {
  id            String      @id @default(cuid())
  ordenCompraId String
  ordenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id])
  fecha         DateTime
  monto         Decimal     @db.Decimal(18, 4)
  moneda        String      @default("CLP")
  tipoPago      TipoPago
  referencia    String?
  observaciones String?
  createdBy     String
  createdAt     DateTime    @default(now())
}

enum TipoPago {
  TRANSFERENCIA
  CHEQUE
  EFECTIVO
  OTRO
}

// ─── OPERACIONES / STOCK ─────────────────────────────────────────────────────

model StockLote {
  id              String        @id @default(cuid())
  codigo          String        @unique
  ordenCompraId   String?
  ordenCompra     OrdenCompra?  @relation(fields: [ordenCompraId], references: [id])
  variedadId      String
  variedad        VariedadLegacy @relation(fields: [variedadId], references: [id])
  temporada       String
  fechaRecepcion  DateTime
  calibre         String?
  categoria       String?
  cantidadCajas   Decimal       @db.Decimal(18, 4)
  pesoNeto        Decimal?      @db.Decimal(18, 4)
  estadoCalidad   CalidadEstado @default(PENDIENTE)
  observaciones   String?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  movimientos    StockMovimiento[]
  notaVentaItems NotaVentaItem[]
}

enum CalidadEstado {
  PENDIENTE
  APROBADO
  RECHAZADO
  APROBADO_CONDICIONADO
}

model StockMovimiento {
  id            String         @id @default(cuid())
  loteId        String
  lote          StockLote      @relation(fields: [loteId], references: [id])
  tipo          MovimientoTipo
  cantidad      Decimal        @db.Decimal(18, 4)
  referencia    String?
  observaciones String?
  createdBy     String
  createdAt     DateTime       @default(now())
}

enum MovimientoTipo {
  INGRESO
  DESPACHO_EXPORTACION
  MERMA
  AJUSTE
}

// ─── MATERIALES ──────────────────────────────────────────────────────────────

model Material {
  id             String   @id @default(cuid())
  codigo         String   @unique
  nombre         String
  unidad         String
  precioUnitario Decimal  @db.Decimal(18, 4)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── VENTAS ──────────────────────────────────────────────────────────────────

model NotaVenta {
  id             String      @id @default(cuid())
  numero         String      @unique
  clienteId      String
  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  fechaEmision   DateTime
  fechaEmbarque  DateTime?
  mercado        MercadoType
  puertoDestino  String?
  incoterm       String?
  moneda         String      @default("USD")
  estado         NvEstado    @default(BORRADOR)
  observaciones  String?
  montoTotal     Decimal     @db.Decimal(18, 4)
  createdBy      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  items         NotaVentaItem[]
  cobranzas     Cobranza[]
  documentosDTE DocumentoDTE[]
}

enum NvEstado {
  BORRADOR
  CONFIRMADA
  EMBARCADA
  EN_TRANSITO
  ENTREGADA
  LIQUIDADA
  ANULADA
}

model NotaVentaItem {
  id             String    @id @default(cuid())
  notaVentaId    String
  notaVenta      NotaVenta @relation(fields: [notaVentaId], references: [id])
  loteId         String
  lote           StockLote @relation(fields: [loteId], references: [id])
  cantidad       Decimal   @db.Decimal(18, 4)
  precioUnitario Decimal   @db.Decimal(18, 4)
  montoTotal     Decimal   @db.Decimal(18, 4)
  descripcion    String?
}

// ─── COBRANZA ────────────────────────────────────────────────────────────────

model Cobranza {
  id               String         @id @default(cuid())
  notaVentaId      String
  notaVenta        NotaVenta      @relation(fields: [notaVentaId], references: [id])
  fechaVencimiento DateTime
  monto            Decimal        @db.Decimal(18, 4)
  moneda           String         @default("USD")
  estado           CobranzaEstado @default(PENDIENTE)
  fechaPago        DateTime?
  montoPagado      Decimal?       @db.Decimal(18, 4)
  referencia       String?
  observaciones    String?
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum CobranzaEstado {
  PENDIENTE
  PARCIAL
  PAGADA
  VENCIDA
  INCOBRABLE
}

// ─── FINANZAS / COSTOS ───────────────────────────────────────────────────────

model CostoOperacional {
  id          String   @id @default(cuid())
  tipo        String
  descripcion String
  monto       Decimal  @db.Decimal(18, 4)
  moneda      String   @default("USD")
  fecha       DateTime
  referencia  String?
  notaVentaId String?
  createdBy   String
  createdAt   DateTime @default(now())
}

// ─── FACTURACIÓN DTE ─────────────────────────────────────────────────────────

model DocumentoDTE {
  id           String    @id @default(cuid())
  notaVentaId  String?
  notaVenta    NotaVenta? @relation(fields: [notaVentaId], references: [id])
  tipoDTE      Int
  folio        Int?
  fecha        DateTime
  rutEmisor    String
  rutReceptor  String
  montoNeto    Decimal   @db.Decimal(18, 4)
  montoIva     Decimal   @db.Decimal(18, 4)
  montoTotal   Decimal   @db.Decimal(18, 4)
  estado       DteEstado @default(PENDIENTE)
  proveedorRef String?
  xmlTimbrado  String?
  pdfUrl       String?
  errorMensaje String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum DteEstado {
  PENDIENTE
  ENVIADO
  ACEPTADO
  RECHAZADO
  ANULADO
}

// ─── CALIDAD ─────────────────────────────────────────────────────────────────

model InspeccionCalidad {
  id              String        @id @default(cuid())
  loteId          String        @unique
  fecha           DateTime
  inspector       String
  temperatura     Decimal?      @db.Decimal(5, 2)
  brix            Decimal?      @db.Decimal(5, 2)
  firmeza         String?
  coloracion      String?
  presenciaPlagas Boolean       @default(false)
  resultado       CalidadEstado
  observaciones   String?
  createdBy       String
  createdAt       DateTime      @default(now())
}

// ─── CONFIGURACIÓN / MANTENEDORES SIMPLES ───────────────────────────────────

model Pais {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  esPaisOrigen          Boolean   @default(false)
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  mercados              Mercado[]
  puertos               Puerto[]
  entidades             Entidad[]          @relation("EntidadPais")
  entidadDirecciones    EntidadDireccion[] @relation("DireccionPais")

  @@map("paises")
}

model Zona {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  predios               Predio[]

  @@map("zonas")
}

model GrupoMercado {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  mercados              Mercado[]

  @@map("grupos_mercado")
}

model TipoEmbarque {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  puertos               Puerto[]

  @@map("tipos_embarque")
}

model UnidadMedida {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  especies              Especie[] @relation("UnidadMedidaCalidadEspecie")
  articulos             Articulo[]

  @@map("unidades_medida")
}

model TipoPallet {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("tipos_pallet")
}

model Altura {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("alturas")
}

model TipoProduccion {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  predios               Predio[]

  @@map("tipos_produccion")
}

model TipoDefecto {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("tipos_defecto")
}

model TipoParametro {
  id                    Int         @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime    @default(now())
  creadoPor             String
  actualizadoEn         DateTime?   @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  parametros            Parametro[]

  @@map("tipos_parametro")
}

// ─── CONFIGURACIÓN / MANTENEDORES CON FK ────────────────────────────────────

model Region {
  id                    Int         @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime    @default(now())
  creadoPor             String
  actualizadoEn         DateTime?   @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  provincias            Provincia[]

  @@map("regiones")
}

model Provincia {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  regionId              Int
  region                Region    @relation(fields: [regionId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  comunas               Comuna[]

  @@map("provincias")
}

model Comuna {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  provinciaId           Int
  provincia             Provincia @relation(fields: [provinciaId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  bodegas               Bodega[]
  entidadDirecciones    EntidadDireccion[]
  predios               Predio[]

  @@map("comunas")
}

model Especie {
  id                      Int            @id @default(autoincrement())
  codigo                  String
  descripcion             String
  descripcionExtranjera   String?
  unidadMedidaCalidadId   Int?
  unidadMedidaCalidad     UnidadMedida?  @relation("UnidadMedidaCalidadEspecie", fields: [unidadMedidaCalidadId], references: [id])
  bloqueado               Boolean        @default(false)
  creadoEn                DateTime       @default(now())
  creadoPor               String
  actualizadoEn           DateTime?      @updatedAt
  actualizadoPor          String?
  eliminadoEn             DateTime?
  eliminadoPor            String?

  gruposVariedad          GrupoVariedad[]
  variedades              Variedad[]
  categorias              Categoria[]
  calibres                Calibre[]
  solicitudesInspeccion   SolicitudInspeccion[]
  conceptosLiquidacion    ConceptoLiquidacionEspecie[]

  @@map("especies")
}

model GrupoVariedad {
  id                    Int        @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  especieId             Int
  especie               Especie    @relation(fields: [especieId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime   @default(now())
  creadoPor             String
  actualizadoEn         DateTime?  @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  variedades            Variedad[]

  @@map("grupos_variedad")
}

model Variedad {
  id                    Int            @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  especieId             Int
  especie               Especie        @relation(fields: [especieId], references: [id])
  grupoVariedadId       Int?
  grupoVariedad         GrupoVariedad? @relation(fields: [grupoVariedadId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime       @default(now())
  creadoPor             String
  actualizadoEn         DateTime?      @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("variedades")
}

model Categoria {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  especieId             Int
  especie               Especie   @relation(fields: [especieId], references: [id])
  orden                 Int
  control               String[]
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("categorias")
}

model Calibre {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  especieId             Int
  especie               Especie   @relation(fields: [especieId], references: [id])
  orden                 Int
  control               String[]
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("calibres")
}

model Parametro {
  id                    Int           @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  tipoParametroId       Int
  tipoParametro         TipoParametro @relation(fields: [tipoParametroId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime      @default(now())
  creadoPor             String
  actualizadoEn         DateTime?     @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("parametros")
}

model Mercado {
  id                    Int          @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  grupoMercadoId        Int
  grupoMercado          GrupoMercado @relation(fields: [grupoMercadoId], references: [id])
  paisId                Int
  pais                  Pais         @relation(fields: [paisId], references: [id])
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime     @default(now())
  creadoPor             String
  actualizadoEn         DateTime?    @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("mercados")
}

model Puerto {
  id                    Int          @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  paisId                Int
  pais                  Pais         @relation(fields: [paisId], references: [id])
  tipoEmbarqueId        Int
  tipoEmbarque          TipoEmbarque @relation(fields: [tipoEmbarqueId], references: [id])
  latitud               Decimal?     @db.Decimal(10, 7)
  longitud              Decimal?     @db.Decimal(10, 7)
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime     @default(now())
  creadoPor             String
  actualizadoEn         DateTime?    @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  @@map("puertos")
}

model Moneda {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  esMonedaBase          Boolean   @default(false)
  decimales             Int       @default(2)
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  movimientosCC         MovimientoCuentaCorriente[]

  @@map("monedas")
}

enum NaturalezaCuentaCorriente {
  DEBE
  HABER
  AMBOS
}

enum TipoBodega {
  MATERIALES
  EMBARQUE
  DESPACHO
}

model Temporada {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  fechaInicio           DateTime  @db.Date
  fechaTermino          DateTime  @db.Date
  predeterminada        Boolean   @default(false)
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  solicitudesInspeccion SolicitudInspeccion[]
  contratosProductor    ProductorContrato[]

  @@map("temporadas")
}

model Bodega {
  id                    Int              @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  direccion             String
  comunaId              Int
  comuna                Comuna           @relation(fields: [comunaId], references: [id])
  tipos                 TipoBodega[]
  latitud               Decimal?         @db.Decimal(10, 7)
  longitud              Decimal?         @db.Decimal(10, 7)
  bloqueado             Boolean          @default(false)
  creadoEn              DateTime         @default(now())
  creadoPor             String
  actualizadoEn         DateTime?        @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  contactos             BodegaContacto[]
  saldos                SaldoArticulo[]
  movimientosOrigen     Movimiento[]     @relation("MovOrigen")
  movimientosDestino    Movimiento[]     @relation("MovDestino")

  @@map("bodegas")
}

model BodegaContacto {
  id        Int      @id @default(autoincrement())
  bodegaId  Int
  bodega    Bodega   @relation(fields: [bodegaId], references: [id])
  nombre    String
  email     String?
  telefono  String?
  orden     Int      @default(0)
  creadoEn  DateTime @default(now())

  @@map("bodega_contactos")
}

model ConceptoCtaCte {
  id                    Int                       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  naturaleza            NaturalezaCuentaCorriente
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime                  @default(now())
  creadoPor             String
  actualizadoEn         DateTime?                 @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  movimientosCC         MovimientoCuentaCorriente[]

  @@map("conceptos_cta_cte")
}

// ─── ENTIDADES ────────────────────────────────────────────────────────────────

enum TipoEntidad {
  CLIENTE_NACIONAL
  CLIENTE_EXTRANJERO
  NOTIFY
  CONSIGNATARIO
  NAVIERA
  AGENTE_ADUANA
  COMPANIA_EMBARQUE
  PROVEEDOR
  EMPRESA_TRANSPORTE
  PRODUCTOR
  EXPORTADORA
  PLANTA
}

model Entidad {
  id                    Int               @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  razonSocial           String
  giro                  String?
  identificador         String?
  paisId                Int
  pais                  Pais              @relation("EntidadPais", fields: [paisId], references: [id])
  email                 String?
  telefono              String?
  codigoExterno         String?
  activo                Boolean           @default(true)
  tipos                 TipoEntidad[]
  creadoEn              DateTime          @default(now())
  creadoPor             String
  actualizadoEn         DateTime?         @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?
  direcciones           EntidadDireccion[]
  contactos             EntidadContacto[]
  solicitudesInspeccion SolicitudInspeccion[]
  movimientos           Movimiento[]          @relation("MovEntidad")
  movimientosTransporte Movimiento[]          @relation("MovTransporte")
  predios               Predio[]              @relation("PrediosProductor")
  contratos             ProductorContrato[]   @relation("ContratosProductor")
  movimientosCC         MovimientoCuentaCorriente[] @relation("CCProductor")

  @@index([eliminadoEn])
  @@map("entidades")
}

model EntidadDireccion {
  id             Int       @id @default(autoincrement())
  entidadId      Int
  entidad        Entidad   @relation(fields: [entidadId], references: [id])
  codigo         String
  paisId         Int
  pais           Pais      @relation("DireccionPais", fields: [paisId], references: [id])
  comunaId       Int?
  comuna         Comuna?   @relation(fields: [comunaId], references: [id])
  direccion      String
  esPorDefecto   Boolean   @default(false)
  latitud        Decimal?  @db.Decimal(10, 7)
  longitud       Decimal?  @db.Decimal(10, 7)
  creadoEn       DateTime  @default(now())
  creadoPor      String
  actualizadoEn  DateTime? @updatedAt
  actualizadoPor String?
  eliminadoEn    DateTime?
  eliminadoPor   String?

  solicitudesInspeccion SolicitudInspeccion[]

  @@index([entidadId])
  @@map("entidad_direcciones")
}

model EntidadContacto {
  id                   Int       @id @default(autoincrement())
  entidadId            Int
  entidad              Entidad   @relation(fields: [entidadId], references: [id])
  codigo               String
  nombre               String
  rut                  String?
  whatsapp             String?
  email                String?
  telefono             String?
  tipo                 String?
  esRepresentanteLegal Boolean   @default(false)
  creadoEn             DateTime  @default(now())
  creadoPor            String
  actualizadoEn        DateTime? @updatedAt
  actualizadoPor       String?
  eliminadoEn          DateTime?
  eliminadoPor         String?

  solicitudesInspeccion SolicitudInspeccion[]

  @@index([entidadId])
  @@map("entidad_contactos")
}

// ─── Calidad — Solicitudes de Inspección ─────────────────────────────────────

enum EstadoSolicitudInspeccion {
  PENDIENTE
  NOTIFICADA
  CERRADA
}

enum FuncionAsignadoInspeccion {
  ACUDIR
  NOTIFICAR
}

// Mantenedor: Motivo de Inspección (base común de mantenedores generales)
model MotivoInspeccion {
  id                    Int       @id @default(autoincrement())
  codigo                String
  descripcion           String
  descripcionExtranjera String?
  bloqueado             Boolean   @default(false)
  creadoEn              DateTime  @default(now())
  creadoPor             String
  actualizadoEn         DateTime? @updatedAt
  actualizadoPor        String?
  eliminadoEn           DateTime?
  eliminadoPor          String?

  solicitudes           SolicitudInspeccion[]

  @@map("motivos_inspeccion")
}

model SolicitudInspeccion {
  id                 Int                       @id @default(autoincrement())
  numero             Int                       // correlativo por temporada
  codigo             String                    // SI-{codTemporada}-{NNNN}
  temporadaId        Int
  temporada          Temporada                 @relation(fields: [temporadaId], references: [id])
  entidadProductorId Int                       // Entidad tipo PRODUCTOR
  entidadProductor   Entidad                   @relation(fields: [entidadProductorId], references: [id])
  direccionId        Int                       // EntidadDireccion de la entidad productora
  direccion          EntidadDireccion          @relation(fields: [direccionId], references: [id])
  contactoId         Int?                      // EntidadContacto de la entidad productora (opcional)
  contacto           EntidadContacto?          @relation(fields: [contactoId], references: [id])
  especieId          Int?
  especie            Especie?                  @relation(fields: [especieId], references: [id])
  fechaHora          DateTime                  // fecha y hora de la visita
  motivoId           Int
  motivo             MotivoInspeccion          @relation(fields: [motivoId], references: [id])
  observaciones      String?
  estado             EstadoSolicitudInspeccion @default(PENDIENTE)
  notificadaEn       DateTime?
  recordatorioEnviadoEn DateTime?
  comentariosCierre  String?
  fechaCierre        DateTime?
  cerradaPor         String?                   // Usuario
  creadoEn           DateTime                  @default(now())
  creadoPor          String                    // solicitante
  actualizadoEn      DateTime?                 @updatedAt
  actualizadoPor     String?
  eliminadoEn        DateTime?
  eliminadoPor       String?

  asignados          SolicitudInspeccionAsignado[]
  adjuntos           SolicitudInspeccionAdjunto[]

  @@unique([temporadaId, numero])
  @@index([estado])
  @@index([entidadProductorId])
  @@index([eliminadoEn])
  @@map("solicitudes_inspeccion")
}

model SolicitudInspeccionAsignado {
  id          Int                       @id @default(autoincrement())
  solicitudId Int
  solicitud   SolicitudInspeccion       @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario                   @relation(fields: [usuarioId], references: [id])
  funcion     FuncionAsignadoInspeccion

  @@unique([solicitudId, usuarioId])
  @@map("solicitud_inspeccion_asignados")
}

// Metadatos del adjunto — el binario vive en tabla aparte para no cargar blobs al listar
model SolicitudInspeccionAdjunto {
  id          Int                 @id @default(autoincrement())
  solicitudId Int
  solicitud   SolicitudInspeccion @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  nombre      String
  mime        String
  tamano      Int                 // bytes
  etapa       String              // CREACION | CIERRE
  subidoEn    DateTime            @default(now())
  subidoPor   String              // Usuario

  contenido   SolicitudInspeccionAdjuntoContenido?

  @@index([solicitudId])
  @@map("solicitud_inspeccion_adjuntos")
}

model SolicitudInspeccionAdjuntoContenido {
  adjuntoId Int                        @id
  adjunto   SolicitudInspeccionAdjunto @relation(fields: [adjuntoId], references: [id], onDelete: Cascade)
  datos     Bytes

  @@map("solicitud_inspeccion_adjuntos_contenido")
}

// ─── Configuración de correo (SMTP) ──────────────────────────────────────────

model ConfiguracionCorreo {
  id              Int       @id @default(autoincrement())
  host            String                        // ej. smtp.office365.com
  puerto          Int       @default(587)
  seguridad       String    @default("STARTTLS") // STARTTLS | SSL | NINGUNA
  usuario         String                        // casilla que autentica
  passwordCifrada String                        // AES-256-GCM, nunca se expone por API
  remitenteNombre String
  remitenteEmail  String
  creadoEn        DateTime  @default(now())
  creadoPor       String
  actualizadoEn   DateTime? @updatedAt
  actualizadoPor  String?

  @@map("configuracion_correo")
}

// ─── Materiales — Maestro de artículos, recetas y movimientos ───────────────

enum TipoArticulo {
  EMBALAJE
  ENVASE
  MATERIAL_EMBALAJE
  SERVICIO
}

enum TipoCosteo {
  PROMEDIO_PONDERADO
  ESTANDAR
}

enum ModuloSistema {
  MATERIALES
  FRUTA
}

enum ClaseMovimiento {
  ENTRADA
  SALIDA
  TRASLADO
}

model Articulo {
  id                    Int          @id @default(autoincrement())
  tipo                  TipoArticulo
  codigo                String       @unique
  descripcion           String
  descripcionExtranjera String?
  unidadId              Int
  unidad                UnidadMedida @relation(fields: [unidadId], references: [id])
  tipoCosteo            TipoCosteo
  valorEstandar         Decimal?     @db.Decimal(14, 4) // requerido si ESTANDAR (R3)
  controlaStock         Boolean      @default(true)     // false si ESTANDAR (R3)
  stockCritico          Decimal?     @db.Decimal(14, 3)
  activo                Boolean      @default(true)

  documentos            DocumentoArticulo[]
  recetas               Receta[]            @relation("EmbalajeRecetas")
  comoComponente        RecetaDetalle[]     @relation("ComponenteRecetas")
  saldos                SaldoArticulo[]
  movimientosDetalle    MovimientoDetalle[]

  creadoEn              DateTime     @default(now())
  actualizadoEn         DateTime     @updatedAt

  @@index([tipo])
  @@index([activo])
  @@map("articulos")
}

model DocumentoArticulo {
  id          Int      @id @default(autoincrement())
  articuloId  Int
  articulo    Articulo @relation(fields: [articuloId], references: [id])
  nombre      String
  mime        String
  tamano      Int
  subidoPor   String
  creadoEn    DateTime @default(now())

  contenido   DocumentoArticuloContenido?

  @@index([articuloId])
  @@map("documentos_articulo")
}

// Metadatos separados del binario (mismo patrón que adjuntos de Solicitud de Inspección, SI-2)
model DocumentoArticuloContenido {
  documentoId Int               @id
  documento   DocumentoArticulo @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  datos       Bytes

  @@map("documentos_articulo_contenido")
}

model Receta {
  id                Int      @id @default(autoincrement())
  embalajeId        Int                                 // FK a Articulo tipo EMBALAJE (R13)
  embalaje          Articulo @relation("EmbalajeRecetas", fields: [embalajeId], references: [id])
  codigo            String   @unique
  descripcion       String
  cantidadAProducir Decimal  @db.Decimal(14, 3)
  activo            Boolean  @default(true)

  detalle           RecetaDetalle[]

  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt

  @@index([embalajeId])
  @@map("recetas")
}

model RecetaDetalle {
  id                Int      @id @default(autoincrement())
  recetaId          Int
  receta            Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  componenteId      Int                                 // FK a Articulo MATERIAL_EMBALAJE o SERVICIO (R13)
  componente        Articulo @relation("ComponenteRecetas", fields: [componenteId], references: [id])
  cantidadAConsumir Decimal  @db.Decimal(14, 4)

  @@index([recetaId])
  @@map("receta_detalles")
}

model TipoMovimiento {
  id                 Int             @id @default(autoincrement())
  codigo             String          @unique
  descripcion        String
  modulos            ModuloSistema[]
  clase              ClaseMovimiento
  requierePrecio     Boolean         @default(false)
  entidadRelacionada TipoEntidad?
  emiteDTE           Boolean         @default(false)
  activo             Boolean         @default(true)

  movimientos        Movimiento[]

  creadoEn           DateTime        @default(now())

  @@index([clase])
  @@map("tipos_movimiento")
}

model SaldoArticulo {
  id            Int      @id @default(autoincrement())
  articuloId    Int
  articulo      Articulo @relation(fields: [articuloId], references: [id])
  bodegaId      Int
  bodega        Bodega   @relation(fields: [bodegaId], references: [id])
  cantidad      Decimal  @db.Decimal(14, 3) @default(0)
  costoPromedio Decimal  @db.Decimal(14, 4) @default(0)
  actualizadoEn DateTime @updatedAt

  @@unique([articuloId, bodegaId])
  @@index([articuloId])
  @@map("saldos_articulo")
}

model Movimiento {
  id                  Int             @id @default(autoincrement())
  tipoMovimientoId    Int
  tipoMovimiento      TipoMovimiento  @relation(fields: [tipoMovimientoId], references: [id])
  entidadId           Int?
  entidad             Entidad?        @relation("MovEntidad", fields: [entidadId], references: [id])
  fechaRegistro        DateTime        @default(now())
  fechaMovimiento      DateTime
  bodegaOrigenId       Int?
  bodegaOrigen         Bodega?         @relation("MovOrigen", fields: [bodegaOrigenId], references: [id])
  bodegaDestinoId      Int?
  bodegaDestino        Bodega?         @relation("MovDestino", fields: [bodegaDestinoId], references: [id])
  guiaReferencia       String?

  // Datos de transporte — requeridos si tipoMovimiento.emiteDTE = true (R10)
  transporteEntidadId  Int?
  transporteEntidad    Entidad?        @relation("MovTransporte", fields: [transporteEntidadId], references: [id])
  choferRut            String?
  choferNombre         String?
  placaCamion          String?
  placaRemolque        String?
  horaSalida           DateTime?
  horaEstimadaLlegada  DateTime?

  detalle              MovimientoDetalle[]
  usuarioId            String
  creadoEn             DateTime        @default(now())

  @@index([tipoMovimientoId])
  @@index([fechaMovimiento])
  @@map("movimientos")
}

model MovimientoDetalle {
  id             Int        @id @default(autoincrement())
  movimientoId   Int
  movimiento     Movimiento @relation(fields: [movimientoId], references: [id], onDelete: Cascade)
  articuloId     Int
  articulo       Articulo   @relation(fields: [articuloId], references: [id])
  cantidad       Decimal    @db.Decimal(14, 3)
  precioUnitario Decimal?   @db.Decimal(14, 4)

  @@index([movimientoId])
  @@index([articuloId])
  @@map("movimiento_detalles")
}

// ─── Productores — Predios, Contrato, Cuenta Corriente, Conceptos de Liquidación ─

enum UnidadVolumen {
  KG
  CAJAS
}

enum NaturalezaMovimientoCC {
  DEBE
  HABER
}

enum FormaAplicacionConcepto {
  POR_KILO
  POR_CAJA
  PORCENTAJE_VENTA
  MONTO_TOTAL
}

enum NaturalezaConcepto {
  COBRO
  ABONO
}

model Predio {
  id               Int             @id @default(autoincrement())
  entidadId        Int                                       // Entidad tipo PRODUCTOR (R1)
  entidad          Entidad         @relation("PrediosProductor", fields: [entidadId], references: [id])
  codigo           String                                    // único por productor (R2, índice parcial)
  descripcion      String
  codigoCsg        String?
  nombreCsg        String?
  codigoSdp        String?
  codigoGgn        String?
  direccion        String?
  comunaId         Int?
  comuna           Comuna?         @relation(fields: [comunaId], references: [id])
  tipoProduccionId Int?
  tipoProduccion   TipoProduccion? @relation(fields: [tipoProduccionId], references: [id])
  zonaId           Int?
  zona             Zona?           @relation(fields: [zonaId], references: [id])
  latitud          Decimal?        @db.Decimal(10, 7)
  longitud         Decimal?        @db.Decimal(10, 7)

  creadoEn         DateTime        @default(now())
  creadoPor        String
  actualizadoEn    DateTime?       @updatedAt
  actualizadoPor   String?
  eliminadoEn      DateTime?
  eliminadoPor     String?

  @@index([entidadId])
  @@map("predios")
}

model ProductorContrato {
  id                     Int            @id @default(autoincrement())
  entidadId              Int
  entidad                Entidad        @relation("ContratosProductor", fields: [entidadId], references: [id])
  temporadaId            Int?
  temporada              Temporada?     @relation(fields: [temporadaId], references: [id])
  pdfNombre              String?
  pdfMime                String?
  pdfTamano              Int?
  fechaInicio            DateTime?      @db.Date
  fechaTermino           DateTime?      @db.Date

  // Condiciones controladas durante el proceso (⚠ semántica a refinar en Etapa 3, ver §3)
  valoresFacturacion     String?
  condicionesPago        String?
  condicionesFacturacion String?
  volumenComprometido    Decimal?       @db.Decimal(14, 3)
  unidadVolumen          UnidadVolumen?
  minimoGarantizado      Decimal?       @db.Decimal(14, 4)
  // porcentajeCumplimiento: CALCULADO (volumen real / comprometido), no se almacena (R5b)

  creadoEn               DateTime       @default(now())
  creadoPor              String
  actualizadoEn          DateTime?      @updatedAt
  actualizadoPor         String?
  eliminadoEn            DateTime?
  eliminadoPor           String?

  pdfContenido           ProductorContratoPdf?

  @@index([entidadId])
  @@map("productor_contratos")
}

// Metadatos separados del binario (mismo patrón que adjuntos de Solicitud de Inspección)
model ProductorContratoPdf {
  contratoId Int               @id
  contrato   ProductorContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  datos      Bytes

  @@map("productor_contratos_pdf")
}

model MovimientoCuentaCorriente {
  id          Int                    @id @default(autoincrement()) // operativo, inmutable (R5)
  entidadId   Int                                                  // productor
  entidad     Entidad                @relation("CCProductor", fields: [entidadId], references: [id])
  tipoId      Int
  tipo        ConceptoCtaCte         @relation(fields: [tipoId], references: [id])
  naturaleza  NaturalezaMovimientoCC                               // DEBE o HABER (consistente con tipo.naturaleza, R6)
  fecha       DateTime
  glosa       String?
  monto       Decimal                @db.Decimal(14, 4)
  monedaId    Int?
  moneda      Moneda?                @relation(fields: [monedaId], references: [id])
  referencia  String?
  temporadaId Int?
  usuarioId   String
  creadoEn    DateTime               @default(now())

  @@index([entidadId, fecha])
  @@index([tipoId])
  @@map("movimientos_cuenta_corriente")
}

model ConceptoLiquidacion {
  id              Int                          @id @default(autoincrement())
  codigo          String
  descripcion     String
  formaAplicacion FormaAplicacionConcepto
  naturaleza      NaturalezaConcepto                               // COBRO (−) / ABONO (+)
  valores         ConceptoLiquidacionEspecie[]

  creadoEn        DateTime  @default(now())
  creadoPor       String
  actualizadoEn   DateTime? @updatedAt
  actualizadoPor  String?
  eliminadoEn     DateTime?
  eliminadoPor    String?

  @@map("conceptos_liquidacion")
}

model ConceptoLiquidacionEspecie {
  id         Int                 @id @default(autoincrement())
  conceptoId Int
  concepto   ConceptoLiquidacion @relation(fields: [conceptoId], references: [id], onDelete: Cascade)
  especieId  Int
  especie    Especie             @relation(fields: [especieId], references: [id])
  valor      Decimal             @db.Decimal(14, 4)               // valor del concepto para esa especie

  @@unique([conceptoId, especieId])
  @@index([conceptoId])
  @@map("conceptos_liquidacion_especie")
}
